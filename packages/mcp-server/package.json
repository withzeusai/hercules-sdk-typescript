{
  "name": "@usehercules/mcp",
  "version": "1.15.3",
  "description": "The official MCP Server for the Hercules API",
  "author": "Hercules <hello@hercules.app>",
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/withzeusai/hercules-sdk-typescript.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/withzeusai/hercules-sdk-typescript/tree/main/packages/mcp-server#readme",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.30.1",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "jest",
    "build": "bash ./build",
    "prepack": "echo 'to pack, run pnpm build && (cd dist; pnpm pack)' && exit 1",
    "prepublishOnly": "echo 'to publish, run pnpm build && (cd dist; pnpm publish)' && exit 1",
    "format": "prettier --write --cache --cache-strategy metadata . !dist",
    "tsn": "ts-node -r tsconfig-paths/register",
    "lint": "eslint .",
    "fix": "eslint --fix ."
  },
  "dependencies": {
    "@cloudflare/cabidela": "^0.2.4",
    "@hono/node-server": "^1.19.14",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@usehercules/sdk": "workspace:*",
    "@valtown/deno-http-worker": "^0.0.21",
    "ajv": "^8.20.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fuse.js": "^7.4.2",
    "hono": "^4.12.25",
    "jq-web": "https://github.com/stainless-api/jq-web/releases/download/v0.8.8/jq-web.tar.gz",
    "minisearch": "^7.2.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "qs": "^6.15.2",
    "typescript": "5.8.3",
    "yargs": "^17.7.2",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2",
    "zod-validation-error": "^4.0.2"
  },
  "bin": {
    "mcp-server": "dist/index.js"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/qs": "^6.15.1",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "8.31.1",
    "@typescript-eslint/parser": "8.31.1",
    "eslint": "^9.39.4",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^29.7.0",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "ts-morph": "^19.0.0",
    "ts-node": "^10.9.2",
    "tsc-multi": "https://github.com/stainless-api/tsc-multi/releases/download/v1.1.11/tsc-multi.tgz",
    "tsconfig-paths": "^4.2.0"
  },
  "imports": {
    "@usehercules/mcp": ".",
    "@usehercules/mcp/*": "./src/*"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./*.mjs": "./dist/*.mjs",
    "./*.js": "./dist/*.js",
    "./*": {
      "require": "./dist/*.js",
      "default": "./dist/*.mjs"
    }
  }
}
